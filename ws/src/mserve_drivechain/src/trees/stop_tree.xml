<!--
  stop_tree — triggered by DriveChainCmd::STOP service call or on deactivate.

  Zeros all enabled motors in motor_list then closes the UART.
  StopAllMotors is best-effort — the tree always succeeds even if motors
  don't echo back (e.g. already powered off).
-->
<root BTCPP_format="4">
  <BehaviorTree ID="Stop">
    <Sequence name="stop">
      <StopAllMotors />
      <CloseUart />
    </Sequence>
  </BehaviorTree>
</root>
