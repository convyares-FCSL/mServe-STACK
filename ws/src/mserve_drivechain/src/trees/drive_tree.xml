<?xml version="1.0"?>
<root BTCPP_format="4">
  <BehaviorTree ID="DriveTree">
    <!--
      Runs every tick timer period (default 100 ms / configured via feedback_rate param).
      UartOpen is a ConditionNode — fails silently if not yet connected (stops motors via watchdog).
      SetAllMotors reads motor_commands cache; sends 0 RPM to all motors if cache is stale.
    -->
    <Sequence name="drive_cycle">
      <UartOpen />
      <SetAllMotors />
      <PublishMotorFeedback />
      <PublishDriveStatus />
    </Sequence>
  </BehaviorTree>
</root>
