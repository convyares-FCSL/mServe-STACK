<!--
  connect_tree — triggered by DriveChainCmd::CONNECT service call.

  Opens the UART then pings and sets speed-loop mode (mode=2) on every enabled
  motor in motor_list (3 ping attempts per motor, handled inside ConnectAllMotors).

  Blackboard inputs (set by load_params):
    uart_device   — e.g. "/dev/ttyAMA0" (Pi 5 GPIO header UART)
    motor_list    — std::vector<MotorDescriptor> built from motor_* params

  In sim mode: OpenUart and ConnectAllMotors succeed immediately.
-->
<root BTCPP_format="4">
  <BehaviorTree ID="Connect">
    <Sequence name="connect">
      <OpenUart device="{uart_device}" baud="115200" />
      <ConnectAllMotors />
    </Sequence>
  </BehaviorTree>
</root>
