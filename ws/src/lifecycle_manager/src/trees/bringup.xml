<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="Main">
    <Sequence name="main">
      <Sequence name="drivechain_sequence">
        <Fallback name="configure_drivechain_fallback">
          <Inverter>
            <IsInState name="is_drivechain_inactive"
                       node_name="mserve_drivechain"
                       state="unconfigured"
                       service_name=""/>
          </Inverter>
          <RetryUntilSuccessful num_attempts="3">
            <ChangeStateNode name="configure_drivechain"
                             node_name="mserve_drivechain"
                             transition="configure"
                             service_name=""/>
          </RetryUntilSuccessful>
        </Fallback>
        <Fallback name="activate_drivechain_fallback">
          <Inverter>
            <IsInState name="is_drivechain_active"
                       node_name="mserve_drivechain"
                       state="inactive"
                       service_name=""/>
          </Inverter>
          <RetryUntilSuccessful num_attempts="3">
            <ChangeStateNode name="activate_drivechain"
                             node_name="mserve_drivechain"
                             transition="activate"
                             service_name=""/>
          </RetryUntilSuccessful>
        </Fallback>
      </Sequence>
      <Sequence name="base_sequence">
        <Fallback name="configure_base_fallback">
          <Inverter>
            <IsInState name="is_base_inactive"
                       node_name="mserve_base"
                       state="unconfigured"
                       service_name=""/>
          </Inverter>
          <RetryUntilSuccessful num_attempts="3">
            <ChangeStateNode name="configure_base"
                             node_name="mserve_base"
                             transition="configure"
                             service_name=""/>
          </RetryUntilSuccessful>
        </Fallback>
        <Fallback name="activate_base_fallback">
          <Inverter>
            <IsInState name="is_base_active"
                       node_name="mserve_base"
                       state="inactive"
                       service_name=""/>
          </Inverter>
          <RetryUntilSuccessful num_attempts="3">
            <ChangeStateNode name="activate_base"
                             node_name="mserve_base"
                             transition="activate"
                             service_name=""/>
          </RetryUntilSuccessful>
        </Fallback>
      </Sequence>
      <Sequence name="camera_sequence">
        <Fallback name="configure_camera_fallback">
          <Inverter>
            <IsInState name="is_camera_inactive"
                       node_name="mserve_camera"
                       state="unconfigured"
                       service_name=""/>
          </Inverter>
          <RetryUntilSuccessful num_attempts="3">
            <ChangeStateNode name="configure_camera"
                             node_name="mserve_camera"
                             transition="configure"
                             service_name=""/>
          </RetryUntilSuccessful>
        </Fallback>
        <Fallback name="activate_camera_fallback">
          <Inverter>
            <IsInState name="is_camera_active"
                       node_name="mserve_camera"
                       state="inactive"
                       service_name=""/>
          </Inverter>
          <RetryUntilSuccessful num_attempts="3">
            <ChangeStateNode name="activate_camera"
                             node_name="mserve_camera"
                             transition="activate"
                             service_name=""/>
          </RetryUntilSuccessful>
        </Fallback>
      </Sequence>
      <Sequence name="lidar_sequence">
        <Fallback name="configure_lidar_fallback">
          <Inverter>
            <IsInState name="is_lidar_inactive"
                       node_name="mserve_lidar"
                       state="unconfigured"
                       service_name=""/>
          </Inverter>
          <RetryUntilSuccessful num_attempts="3">
            <ChangeStateNode name="configure_lidar"
                             node_name="mserve_lidar"
                             transition="configure"
                             service_name=""/>
          </RetryUntilSuccessful>
        </Fallback>
        <Fallback name="activate_lidar_fallback">
          <Inverter>
            <IsInState name="is_lidar_active"
                       node_name="mserve_lidar"
                       state="inactive"
                       service_name=""/>
          </Inverter>
          <RetryUntilSuccessful num_attempts="3">
            <ChangeStateNode name="activate_lidar"
                             node_name="mserve_lidar"
                             transition="activate"
                             service_name=""/>
          </RetryUntilSuccessful>
        </Fallback>
      </Sequence>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="ChangeStateNode">
      <input_port name="node_name"
                  type="std::string"/>
      <input_port name="transition"
                  type="std::string"/>
      <input_port name="service_name"
                  type="std::string">Service name</input_port>
    </Action>
    <Action ID="IsInState">
      <input_port name="node_name"
                  type="std::string"/>
      <input_port name="state"
                  type="std::string"/>
      <input_port name="service_name"
                  type="std::string">Service name</input_port>
    </Action>
  </TreeNodesModel>

</root>
