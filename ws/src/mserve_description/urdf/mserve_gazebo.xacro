<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- Gazebo / physics tuning properties -->
  <xacro:property name="diff_drive_topic" value="cmd_vel"/>
  <xacro:property name="diff_drive_odom_topic" value="odom"/>
  <xacro:property name="diff_drive_tf_topic" value="tf"/>
  <xacro:property name="diff_drive_frame_id" value="odom"/>
  <xacro:property name="diff_drive_child_frame_id" value="base_link"/>
  <xacro:property name="diff_drive_odom_publish_frequency" value="50.0"/>
  <xacro:property name="robot_total_mass" value="${chassis_mass + 2.0 * wheel_mass + caster_mass + lidar_riser_mass + lidar_mass + camera_mass + display_mass + arm_mount_mass}"/>
  <xacro:property name="diff_drive_max_linear_velocity" value="${wheel_rated_velocity * wheel_radius}"/>
  <xacro:property name="diff_drive_max_angular_velocity" value="${2.0 * diff_drive_max_linear_velocity / wheel_separation}"/>
  <xacro:property name="diff_drive_max_linear_acceleration" value="${2.0 * wheel_rated_torque / (wheel_radius * robot_total_mass)}"/>
  <xacro:property name="diff_drive_max_angular_acceleration" value="${2.0 * diff_drive_max_linear_acceleration / wheel_separation}"/>

  <xacro:property name="wheel_contact_mu1" value="1.2"/>
  <xacro:property name="wheel_contact_mu2" value="1.2"/>
  <xacro:property name="wheel_contact_kp" value="1000000.0"/>
  <xacro:property name="wheel_contact_kd" value="100.0"/>
  <xacro:property name="wheel_contact_min_depth" value="0.001"/>
  <xacro:property name="wheel_contact_max_vel" value="1.0"/>

  <xacro:property name="caster_contact_mu1" value="0.05"/>
  <xacro:property name="caster_contact_mu2" value="0.05"/>
  <xacro:property name="caster_contact_kp" value="1000000.0"/>
  <xacro:property name="caster_contact_kd" value="100.0"/>
  <xacro:property name="caster_contact_min_depth" value="0.001"/>
  <xacro:property name="caster_contact_max_vel" value="1.0"/>

  <!-- High friction drive wheels -->
  <gazebo reference="left_wheel">
    <mu1>${wheel_contact_mu1}</mu1>
    <mu2>${wheel_contact_mu2}</mu2>
    <kp>${wheel_contact_kp}</kp>
    <kd>${wheel_contact_kd}</kd>
    <minDepth>${wheel_contact_min_depth}</minDepth>
    <maxVel>${wheel_contact_max_vel}</maxVel>
  </gazebo>

  <gazebo reference="right_wheel">
    <mu1>${wheel_contact_mu1}</mu1>
    <mu2>${wheel_contact_mu2}</mu2>
    <kp>${wheel_contact_kp}</kp>
    <kd>${wheel_contact_kd}</kd>
    <minDepth>${wheel_contact_min_depth}</minDepth>
    <maxVel>${wheel_contact_max_vel}</maxVel>
  </gazebo>

  <!-- Low friction caster so the robot can yaw without fighting a rear wheel -->
  <gazebo reference="caster_wheel">
    <mu1>${caster_contact_mu1}</mu1>
    <mu2>${caster_contact_mu2}</mu2>
    <kp>${caster_contact_kp}</kp>
    <kd>${caster_contact_kd}</kd>
    <minDepth>${caster_contact_min_depth}</minDepth>
    <maxVel>${caster_contact_max_vel}</maxVel>
  </gazebo>

  <!-- Model-specific systems stay with the model in Gazebo Sim -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <topic>${diff_drive_topic}</topic>
      <odom_topic>${diff_drive_odom_topic}</odom_topic>
      <tf_topic>${diff_drive_tf_topic}</tf_topic>
      <frame_id>${diff_drive_frame_id}</frame_id>
      <child_frame_id>${diff_drive_child_frame_id}</child_frame_id>
      <odom_publish_frequency>${diff_drive_odom_publish_frequency}</odom_publish_frequency>
      <max_linear_velocity>${diff_drive_max_linear_velocity}</max_linear_velocity>
      <max_angular_velocity>${diff_drive_max_angular_velocity}</max_angular_velocity>
      <max_linear_acceleration>${diff_drive_max_linear_acceleration}</max_linear_acceleration>
      <max_angular_acceleration>${diff_drive_max_angular_acceleration}</max_angular_acceleration>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </gazebo>
</robot>
