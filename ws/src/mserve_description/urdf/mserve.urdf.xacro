<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mserve_robot">

  <!-- Include the core robot definition -->
  <xacro:include filename="mserve_core.xacro"/>

  <!-- USB webcam (mserve_camera wraps v4l2_camera) — plain RGB, not depth.
       mserve_depth_camera.xacro (kept in the tree, just unused) modeled an
       RGBD camera that doesn't match this hardware — confirmed 2026-07-19. -->
  <xacro:include filename="mserve_camera.xacro"/>
  <xacro:mserve_camera parent_link="chassis"/>

  <!-- Include Lidar -->
  <xacro:include filename="mserve_lidar.xacro"/>
  <xacro:mserve_lidar parent_link="chassis"/>

  <!-- Include Gazebo-specific simulation tuning -->
  <xacro:include filename="mserve_gazebo.xacro"/>
  
</robot>
