<root BTCPP_format="4">
  <BehaviorTree ID="Stop">
    <Sequence name="stop">

      <!-- Stop compression driver -->
      <SetPCSV
        service_name="{service_name}"
        enable="false"
        cpm="0"
      />

      <!-- Wait for hydraulic A and B lines to de-pressurise before closing HPU SV -->
      <PressureBelowThreshold
        pt_index="{hyd_a_pt_index}"
        threshold_bar="{hyd_pressure_threshold_bar}"
        timeout_ms="{hyd_timeout_ms}"
      />

      <PressureBelowThreshold
        pt_index="{hyd_b_pt_index}"
        threshold_bar="{hyd_pressure_threshold_bar}"
        timeout_ms="{hyd_timeout_ms}"
      />

      <!-- Isolate hydraulic circuit -->
      <ControlSV
        service_name="{service_name}"
        sv_index="{hpu_sv_index}"
        enable="false"
      />

      <!-- Wait for primer to confirm hydraulics isolated -->
      <PressureBelowThreshold
        pt_index="{hyd_primer_pt_index}"
        threshold_bar="{hyd_pressure_threshold_bar}"
        timeout_ms="{hyd_timeout_ms}"
      />

      <!-- Ramp down VFD — now unloaded -->
      <StopVFD
        service_name="{service_name}"
      />

      <!-- Shut off H2 supply -->
      <ControlSV
        service_name="{service_name}"
        sv_index="{inlet_sv_index}"
        enable="false"
      />

      <!-- Confirm VFD has fully ramped down before reporting complete -->
      <VFDStopped
        vfd_index="{vfd_index}"
        stop_threshold="{stop_threshold}"
        stop_timeout_ms="{stop_timeout_ms}"
      />

    </Sequence>
  </BehaviorTree>
</root>
