<root BTCPP_format="4">
  <BehaviorTree ID="SafeStop">
    <!-- Uncontrolled shutdown — slam everything off simultaneously.
         No hydraulic checks, no VFD ramp confirmation.
         Used on loss-of-control or safety interlock. -->
    <Parallel success_count="4" failure_count="1">

      <SetPCSV
        service_name="{service_name}"
        enable="false"
        cpm="0"
      />

      <ControlSV
        service_name="{service_name}"
        sv_index="{hpu_sv_index}"
        enable="false"
      />

      <StopVFD
        service_name="{service_name}"
      />

      <ControlSV
        service_name="{service_name}"
        sv_index="{inlet_sv_index}"
        enable="false"
      />

    </Parallel>
  </BehaviorTree>
</root>
