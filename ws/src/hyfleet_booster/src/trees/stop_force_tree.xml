<root BTCPP_format="4">
  <BehaviorTree ID="BoosterMain">
    <Sequence name="stop_force">
      <SetPCSV 
        service_name="{service_name}"
        enable="false"
        cpm="{cpm}" 
      />

      <ControlSV 
        service_name="{service_name}"
        sv_index="{hpu_sv_index}"
        enable="false" 
      />

      <StopVFD 
        service_name="{service_name}" 
      />

      <ControlSV 
        service_name="{service_name}"
        sv_index="{inlet_sv_index}"
        enable="false" 
      />
    </Sequence>
  </BehaviorTree>
</root>