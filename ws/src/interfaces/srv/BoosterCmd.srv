# srv/BoosterCmd.srv
uint8 START_VFD   = 1
uint8 STOP_VFD    = 2
uint8 SET_PCSV    = 3
uint8 CONTROL_SV  = 4

uint8 cmd

bool    enable        # SET_PCSV / CONTROL_SV — energise the targeted device
uint8   index         # CONTROL_SV — index into CompressorTelemetry::sv[5]
float64 setpoint     # START_VFD/SET_PCSV — VFD speed (rpm) & compression rate (cpm)
---
bool    success
string  message