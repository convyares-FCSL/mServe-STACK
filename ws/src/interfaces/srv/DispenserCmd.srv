# srv/DispenserCmd.srv
uint8 INVALID = 0
uint8 START = 1
uint8 STOP = 2
uint8 LOGIN = 3
uint8 LOGOUT = 4
uint8 PAYMENT = 5

uint8 cmd

bool    enable        # SET_PCSV / CONTROL_SV — energise the targeted device
string  guid          # CONTROL_SV — which valve; bridge owns the lookup
float64 pressure      # START_VFD — VFD speed (rpm)

---
bool    success
string  message