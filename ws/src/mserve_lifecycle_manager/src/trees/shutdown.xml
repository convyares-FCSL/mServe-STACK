<root BTCPP_format="4">
    <BehaviorTree ID="Shutdown">
        <Sequence name="main">

            <Sequence name="compression_sequence">
            <Fallback name="shutdown_compression_fallback">
                <IsInState
                    name="is_compression_finalized"
                    node_name="hyfleet_compression"
                    state="finalized"
                />
                <ChangeStateNode
                    name="shutdown_compression"
                    node_name="hyfleet_compression"
                    transition="shutdown"
                />
            </Fallback>
        </Sequence>

        <Sequence name="drivechain_sequence">
                <Fallback name="shutdown_drivechain_fallback">
                    <IsInState
                        name="is_drivechain_inactive"
                        node_name="mserve_drivechain"
                        state="finalized"
                    />
                    <ChangeStateNode
                        name="shutdown_drivechain"
                        node_name="mserve_drivechain"
                        transition="shutdown"
                    />
                </Fallback>
            </Sequence>

        <Sequence name="base_sequence">
            <Fallback name="shutdown_base_fallback">
                <IsInState
                    name="is_base_inactive"
                    node_name="mserve_base"
                    state="finalized"
                />
                <ChangeStateNode
                    name="shutdown_base"
                    node_name="mserve_base"
                    transition="shutdown"
                />
                </Fallback>
            </Sequence>

        </Sequence>
    </BehaviorTree>
</root>