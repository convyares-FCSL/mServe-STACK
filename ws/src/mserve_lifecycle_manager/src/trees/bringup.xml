<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="Main">
    <Sequence name="main">
      <Sequence name="low_booster_sequence">
        <Fallback name="low_booster_fallback">
          <Inverter>
            <IsInState name="is_low_booster_inactive"
                       node_name="low_booster"
                       state="unconfigured"
                       service_name=""/>
          </Inverter>
          <RetryUntilSuccessful num_attempts="3">
            <ChangeStateNode name="configure_low_booster"
                             node_name="low_booster"
                             transition="configure"
                             service_name=""/>
          </RetryUntilSuccessful>
        </Fallback>
        <Fallback name="activate_low_booster_fallback">
          <Inverter>
            <IsInState name="is_low_booster_active"
                       node_name="low_booster"
                       state="inactive"
                       service_name=""/>
          </Inverter>
          <RetryUntilSuccessful num_attempts="3">
            <ChangeStateNode name="activate_low_booster"
                             node_name="low_booster"
                             transition="activate"
                             service_name=""/>
          </RetryUntilSuccessful>
        </Fallback>
      </Sequence>
      <Sequence name="high_booster_sequence">
        <Fallback name="high_booster_fallback">
          <Inverter>
            <IsInState name="is_high_booster_inactive"
                       node_name="high_booster"
                       state="unconfigured"
                       service_name=""/>
          </Inverter>
          <RetryUntilSuccessful num_attempts="3">
            <ChangeStateNode name="configure_high_booster"
                             node_name="high_booster"
                             transition="configure"
                             service_name=""/>
          </RetryUntilSuccessful>
        </Fallback>
        <Fallback name="activate_high_booster_fallback">
          <Inverter>
            <IsInState name="is_high_booster_active"
                       node_name="high_booster"
                       state="inactive"
                       service_name=""/>
          </Inverter>
          <RetryUntilSuccessful num_attempts="3">
            <ChangeStateNode name="activate_high_booster"
                             node_name="high_booster"
                             transition="activate"
                             service_name=""/>
          </RetryUntilSuccessful>
        </Fallback>
      </Sequence>
      <Sequence name="compression_sequence">
        <Fallback name="config_compression_fallback">
          <Inverter>
            <IsInState name="is_compression_inactive"
                       node_name="hyfleet_compression"
                       state="unconfigured"
                       service_name=""/>
          </Inverter>
          <RetryUntilSuccessful num_attempts="3">
            <ChangeStateNode name="configure_compression"
                             node_name="hyfleet_compression"
                             transition="configure"
                             service_name=""/>
          </RetryUntilSuccessful>
        </Fallback>
        <Fallback name="activate_compression_fallback">
          <Inverter>
            <IsInState name="is_compression_active"
                       node_name="hyfleet_compression"
                       state="inactive"
                       service_name=""/>
          </Inverter>
          <RetryUntilSuccessful num_attempts="3">
            <ChangeStateNode name="activate_compression"
                             node_name="hyfleet_compression"
                             transition="activate"
                             service_name=""/>
          </RetryUntilSuccessful>
        </Fallback>
      </Sequence>
    </Sequence> 
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="ChangeStateNode">
      <input_port name="node_name"
                  type="std::string"/>
      <input_port name="transition"
                  type="std::string"/>
      <input_port name="service_name"
                  type="std::string">Service name</input_port>
    </Action>
    <Action ID="IsInState">
      <input_port name="node_name"
                  type="std::string"/>
      <input_port name="state"
                  type="std::string"/>
      <input_port name="service_name"
                  type="std::string">Service name</input_port>
    </Action>
  </TreeNodesModel>

</root>
