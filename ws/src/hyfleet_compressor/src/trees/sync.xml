<root BTCPP_format="4">
  <BehaviorTree ID="sync">
    <!--
      SYNC two-phase operation:

      Phase 1 — Build interstage (SV closed):
        Low booster compresses interstage tank (ON_TARGET_HOLD).
        InterstageAboveBand waits until interstage PT >= start_threshold.

      Phase 2 — Open SV, compress high stage:
        ControlSV opens interstage SV — sim now couples low outlet → high inlet.
        High booster compresses to vehicle target (ON_TARGET_SUCCEED).
        InletGuard on high booster pauses PCSV if interstage droops below
        starvation_bar and resumes when low booster recovers it.

      Parallel success_count=1: BoostHigh returning SUCCESS is the exit condition.
      Low booster is halted by the Parallel, then both receive explicit STOP(2).
      SV is closed in both success and abort paths before stopping boosters.
    -->
    <Fallback>

      <!-- Success path -->
      <Sequence name="sync_run">
        <Timeout msec="{sync_overall_timeout_ms}">
          <Parallel success_count="1" failure_count="1">

            <!-- Low: holds interstage band — COMPRESS(1) + ON_TARGET_HOLD(1) -->
            <BoostLow
              action_name="{low_booster_action}"
              command="1"
              on_target="1"
              target_pressure="{interstage_target_bar}"
              cpm="{cpm}"
              speed_rpm="{speed_rpm}"
              on_inlet_starve="0"
              inlet_starve_bar="-1.0"
              inlet_resume_bar="-1.0"
            />

            <Sequence name="high_stage">
              <!-- Wait for interstage PT >= start threshold before opening SV -->
              <InterstageAboveBand/>
              <!-- Open interstage SV — connects low outlet to high booster inlet -->
              <ControlSV
                service_name="{service_name}"
                enable="true"
                sv_index="{interstage_sv_index}"
              />
              <!-- High compresses to vehicle target; InletGuard pauses on starvation -->
              <BoostHigh
                action_name="{high_booster_action}"
                command="1"
                on_target="0"
                target_pressure="{target_pressure}"
                cpm="{cpm}"
                speed_rpm="{speed_rpm}"
                on_inlet_starve="1"
                inlet_starve_bar="{interstage_starvation_bar}"
                inlet_resume_bar="{interstage_start_threshold_bar}"
              />
            </Sequence>

          </Parallel>
        </Timeout>

        <!-- Parallel succeeded (BoostHigh hit target) — close SV then stop both -->
        <ControlSV
          service_name="{service_name}"
          enable="false"
          sv_index="{interstage_sv_index}"
        />
        <BoostLow
          action_name="{low_booster_action}"
          command="2"
          target_pressure="0"
          cpm="0"
          speed_rpm="0"
        />
        <BoostHigh
          action_name="{high_booster_action}"
          command="2"
          target_pressure="0"
          cpm="0"
          speed_rpm="0"
        />
      </Sequence>

      <!-- Abort path: Parallel failed or timed out — close SV, stop both, propagate FAILURE -->
      <ForceFailure>
        <Sequence name="abort_cleanup">
          <ControlSV
            service_name="{service_name}"
            enable="false"
            sv_index="{interstage_sv_index}"
          />
          <BoostLow
            action_name="{low_booster_action}"
            command="2"
            target_pressure="0"
            cpm="0"
            speed_rpm="0"
          />
          <BoostHigh
            action_name="{high_booster_action}"
            command="2"
            target_pressure="0"
            cpm="0"
            speed_rpm="0"
          />
        </Sequence>
      </ForceFailure>

    </Fallback>
  </BehaviorTree>
</root>
