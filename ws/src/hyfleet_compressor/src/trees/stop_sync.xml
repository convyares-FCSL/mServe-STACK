<root BTCPP_format="4">
  <BehaviorTree ID="stop_sync">
    <!--
      SYNC stop/force-stop path.
      Entered when command != START arrives for SYNC_BOOSTERS target.
      Always closes the interstage SV first (whether or not Phase 2 was reached),
      then stops both boosters. command is read from the blackboard so STOP(2)
      and FORCE_STOP(3) both work without a separate tree.
    -->
    <Sequence>
      <ControlSV
        service_name="{service_name}"
        enable="false"
        sv_index="{interstage_sv_index}"
      />
      <BoostLow
        action_name="{low_booster_action}"
        command="{command}"
        target_pressure="0"
        cpm="0"
        speed_rpm="0"
      />
      <BoostHigh
        action_name="{high_booster_action}"
        command="{command}"
        target_pressure="0"
        cpm="0"
        speed_rpm="0"
      />
    </Sequence>
  </BehaviorTree>
</root>
