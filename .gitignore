.env
.env.local

# mserve_sensehat's RTIMULib settings/calibration — machine/robot-specific
# (calibrated against this exact unit's magnetic environment), not project
# data. See docker-compose.yml's volumes: and ws/src/mserve_sensehat/README.md.
sensehat_calibration/

build/
install/
log/
temp/

# Third-party vendored dependencies (source builds) — see ws/src/third_party/README.md
ws/src/third_party/*/
!ws/src/third_party/README.md

# ROS 2 workspace output
ws/build/
ws/build_host/
ws/install/
ws/install_host/
ws/log/
ws/log_host/
ws/core
ws/src/hyfleet_compressor/archive

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# Editor/system noise
.vscode/
.idea/
.DS_Store
.claude
.codex
.agents